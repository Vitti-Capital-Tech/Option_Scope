VITE_ANTHROPIC_API_KEY=
VITE_GROQ_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: route the browser "Verify Connection" call through a proxy on your
# IP-whitelisted server (see engine/proxyServer.js) instead of the Vercel rewrite,
# so Delta sees your whitelisted IP. Full https origin, NO path suffix.
# e.g. https://delta-proxy.yourdomain.com
VITE_DELTA_PROXY_URL=

# Telegram bot username (WITHOUT the @) used to build the per-account "Connect
# Telegram" deep link (t.me/<username>?start=<code>). Must match the bot behind
# the engine's TELEGRAM_BOT_TOKEN. Frontend-only; the token itself stays server-side.
VITE_TELEGRAM_BOT_USERNAME=