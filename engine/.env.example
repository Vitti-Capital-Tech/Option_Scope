# Supabase Configuration (without VITE_ prefix for server-side use)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Required for LIVE Delta trading: the service_role key lets the engine decrypt
# stored credentials (get_delta_credentials_decrypted is service_role-only).
# Without it, live trading is disabled and paper trading continues normally.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Live order safety switch. TRUE (default) = log intended orders WITHOUT sending.
# Set to false ONLY after validating the dry-run order log against a real account.
DELTA_LIVE_DRYRUN=true
